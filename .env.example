# 将 YOUR_POSTGRES_PASSWORD 替换为安装本机 PostgreSQL 时设置的 postgres 密码
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/margingo
PORT=4173
# Gemini 密钥只保存 AES-256-GCM 密文；运行 npm run encrypt:gemini-key 生成
GEMINI_API_KEY_ENCRYPTED=v1.ENCRYPTED_VALUE
# 解密主密钥不要写入本文件；请通过本机环境变量或云平台 Secret 注入：
# GEMINI_KEY_ENCRYPTION_KEY=<32 字节 Base64 主密钥>
# 默认使用稳定版高性价比模型，可按需覆盖
GEMINI_MODEL=gemini-3.1-flash-lite
# Windows 本机会自动读取系统代理；云服务器需要代理时取消下一行注释
# GEMINI_HTTPS_PROXY=http://127.0.0.1:7890
# 单次 Gemini 请求超时（毫秒）
GEMINI_TIMEOUT_MS=45000
GEMINI_MAX_RETRIES=2
# 仅当前端和 API 分开部署时填写，多个域名用英文逗号分隔
# CORS_ORIGINS=https://example.com
