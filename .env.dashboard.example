PORT=4180
CALCULATOR_URL=http://127.0.0.1:4173
# 本地模式默认从 config/datapool.local.json 读取数据库地址和负责人
AUTH_MODE=local
DATAPOOL_CONFIG_PATH=config/datapool.local.json
DATABASE_URL=
PGSSL=false

# 飞书企业自建应用：开发者后台 > 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-me
# 必须与飞书开发者后台“安全设置 > 重定向 URL”完全一致
FEISHU_REDIRECT_URI=http://127.0.0.1:4180/api/auth/callback

# 至少 32 字节随机字符串，用于签名应用自己的登录态
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=28800

# 仅限本机联调；生产环境必须为 false
DEV_AUTH_BYPASS=false
DEV_AUTH_NAME=测试负责人
