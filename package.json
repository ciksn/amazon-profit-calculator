{
  "name": "amazon-global-margin",
  "version": "0.1.0",
  "private": true,
  "description": "亚马逊多国利润率计算工具",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:dashboard": "node dashboard/server.js",
    "dev:dashboard": "node --watch dashboard/server.js",
    "db:migrate": "node dashboard/migrate.js",
    "db:import:sqlite": "node scripts/import-sqlite-to-postgres.js",
    "sync:datapool": "node scripts/sync-datapool-to-postgres.js",
    "build:pages": "node scripts/build_github_pages.mjs",
    "update:japan-tariff": "node scripts/update_japan_tariff.mjs",
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test --test-coverage-include=lib/profit.js --test-coverage-include=server.js --test-coverage-lines=95 --test-coverage-branches=90 --test-coverage-functions=95"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "pg": "^8.16.3"
  }
}
