POSTGRES_DB=margingo
POSTGRES_USER=margingo
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD
APP_PORT=4173
PG_POOL_MAX=10

# 只放加密后的 Gemini 密钥。可用 npm run encrypt:gemini-key 生成。
GEMINI_API_KEY_ENCRYPTED=v1.REPLACE_WITH_ENCRYPTED_VALUE
# 解密主密钥由云平台 Secret 注入；若只用 Docker Compose，可放在服务器权限受限的 .env.production 中。
GEMINI_KEY_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_MASTER_KEY
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=45000
GEMINI_MAX_RETRIES=2

# 前后端由同一 Node 服务提供时留空。
CORS_ORIGINS=
